<%- messages() %>

<% if (errors) { %>
    <ul class="notice">
   <% errors.array().forEach(error => { %>
     <li><%= error.msg %></li>
  <%  }) %>
   </ul>
<% } %>

<section class="management-content">
    <h2>Welcome <%= locals.accountData.account_firstname %></h2>
    <p>You are logged in.</p>
    
    <div class="user-actions">
        <ul>
            <li>
                <a href="/account/update/<%= locals.accountData.account_id %>">Update Account Information</a>
            </li>
        </ul>
    </div>

    <% if (locals.accountData.account_type === "Employee" || locals.accountData.account_type === "Admin") { %>
        <hr>
        <div class="inventory-mgmt">
            <h3>Inventory Management</h3>
            <p>Use the link below to manage inventory.</p>
            <p><a href="/inv/">Go to Inventory Management</a></p>
        </div>
    <% } %>
</section>